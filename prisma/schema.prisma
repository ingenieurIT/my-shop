generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Store {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  logo      String?
  phone     String?
  email     String?
  address   String?
  city      String?
  website   String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations (on les ajoutera plus tard pour Product)
}

model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  image       String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Brand {
  id        String   @id @default(uuid())
  name      String
  logo      String?
  website   String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}